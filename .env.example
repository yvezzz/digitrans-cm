# Configuration locale pour développement

# Database Configuration
DB_HOST=mysql
DB_PORT=3306
DB_NAME=digitrans_db
DB_USERNAME=digitrans_user
DB_PASSWORD=digitrans_password

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Spring Configuration
SPRING_PROFILES_ACTIVE=dev

# Services Configuration
ERP_SERVICE_HOST=erp-service
ERP_SERVICE_PORT=8081
SUPPLY_CHAIN_SERVICE_HOST=supply-chain-service
SUPPLY_CHAIN_SERVICE_PORT=8082

# AWS Configuration (Désactivé en dev)
AWS_REGION=af-south-1
ENABLE_CLOUDWATCH=false

# Logging
LOG_LEVEL=INFO
